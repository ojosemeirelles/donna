{
  "name": "@donna/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Donna Desktop — zero-friction Electron installer for macOS and Windows",
  "author": "Donna Contributors",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && electron .",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src test",
    "package:mac": "tsc -p tsconfig.json && electron-builder --mac --config electron-builder.yml",
    "package:win": "tsc -p tsconfig.json && electron-builder --win --config electron-builder.yml",
    "package:all": "tsc -p tsconfig.json && electron-builder --mac --win --config electron-builder.yml"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
